#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# better-buddy — Choose your own Claude Code companion
#
# One script. Checks prerequisites, finds your identity, forges a salt,
# patches the binary. Run it and follow the prompts.
#
# Usage:
#   ./better-buddy                                    # Interactive mode
#   ./better-buddy --species dragon --rarity legendary --shiny
#   ./better-buddy --current                          # Show your companion
#   ./better-buddy --check                            # Show patch status
#   ./better-buddy --restore                          # Undo patch
#   ./better-buddy --help
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ORIGINAL_SALT="friend-2026-401"
CONFIG_FILE="${BUDDY_CONFIG:-$HOME/.config/better-buddy/config}"

# ═══════════════════════════════════════════════════════════════════════════════
# Colors
# ═══════════════════════════════════════════════════════════════════════════════

if [[ -t 1 ]]; then
  RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
  CYAN='\033[0;36m'; MAGENTA='\033[0;35m'
  BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; CYAN=''; MAGENTA=''
  BOLD=''; DIM=''; NC=''
fi

# ═══════════════════════════════════════════════════════════════════════════════
# Prerequisites
# ═══════════════════════════════════════════════════════════════════════════════

check_claude() {
  if ! command -v claude &>/dev/null; then
    echo -e "${RED}Claude Code not found in PATH.${NC}"
    echo "  Install: https://docs.anthropic.com/en/docs/claude-code"
    exit 1
  fi
}

check_bun() {
  if command -v bun &>/dev/null; then return 0; fi

  echo -e "${YELLOW}Bun is required${NC} (Claude Code uses Bun.hash — Node.js won't work)."
  echo ""
  read -r -p "  Install Bun now? [Y/n] " response
  if [[ "${response:-Y}" =~ ^[Nn]$ ]]; then
    echo "  Install manually: https://bun.sh"
    exit 1
  fi

  echo ""
  curl -fsSL https://bun.sh/install | bash
  export BUN_INSTALL="${BUN_INSTALL:-$HOME/.bun}"
  export PATH="$BUN_INSTALL/bin:$PATH"

  if ! command -v bun &>/dev/null; then
    echo -e "${RED}Bun installed but not in PATH. Restart your terminal.${NC}"
    exit 1
  fi
  echo -e "${GREEN}✓${NC} Bun installed"
  echo ""
}

check_python() {
  if ! command -v python3 &>/dev/null; then
    echo -e "${RED}python3 not found.${NC} Needed for config parsing."
    exit 1
  fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# Binary helpers
# ═══════════════════════════════════════════════════════════════════════════════

resolve_binary() {
  local p
  p="$(which claude 2>/dev/null)" || return 1
  if [[ "$(uname)" == "Darwin" ]]; then
    python3 -c "import os; print(os.path.realpath('$p'))" 2>/dev/null \
      || greadlink -f "$p" 2>/dev/null || readlink "$p"
  else
    readlink -f "$p"
  fi
}

count_salt() {
  (grep -boa "$2" "$1" 2>/dev/null || true) | wc -l | tr -d ' '
}

is_patched() {
  [[ $(count_salt "$1" "$ORIGINAL_SALT") -eq 0 ]]
}

# ═══════════════════════════════════════════════════════════════════════════════
# Config helpers
# ═══════════════════════════════════════════════════════════════════════════════

config_paths() {
  local paths=("$HOME/.claude.json" "$HOME/.claude/.config")
  if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
    local cc="$CLAUDE_CONFIG_DIR/.claude.json"
    local dup=false
    for p in "${paths[@]}"; do [[ "$p" == "$cc" ]] && dup=true; done
    $dup || paths+=("$cc")
  fi
  echo "${paths[@]}"
}

detect_uuid() {
  local paths; read -ra paths <<< "$(config_paths)"
  for p in "${paths[@]}"; do
    [[ -f "$p" ]] || continue
    local r
    r=$(python3 -c "
import json
try:
    d = json.load(open('$p'))
    u = d.get('oauthAccount',{}).get('accountUuid')
    t = 'oauth' if u else None
    u = u or d.get('userID')
    t = t or 'local'
    if u: print(f'{t}|{u}|$p')
except: pass
" 2>/dev/null) || continue
    [[ -n "$r" ]] && { echo "$r"; return 0; }
  done
  return 1
}

show_companion() {
  local paths; read -ra paths <<< "$(config_paths)"
  for p in "${paths[@]}"; do
    [[ -f "$p" ]] || continue
    python3 -c "
import json
try:
    c = json.load(open('$p')).get('companion')
    if c: print(f\"{c.get('name','?')} — {c.get('personality','?')[:70]}...\")
except: pass
" 2>/dev/null && return 0
  done
  echo "(not hatched yet)"
}

# ═══════════════════════════════════════════════════════════════════════════════
# Patch
# ═══════════════════════════════════════════════════════════════════════════════

save_salt() {
  local salt="$1"
  mkdir -p "$(dirname "$CONFIG_FILE")"
  cat > "$CONFIG_FILE" <<EOF
# better-buddy config — auto-managed, but safe to hand-edit
# This file is read by buddy-ensure.sh and patch.sh
BUDDY_SALT="$salt"
EOF
}

do_patch() {
  local binary="$1" salt="$2" backup="${1}.original"

  if [[ ${#salt} -ne 15 ]]; then
    echo -e "${RED}Salt must be exactly 15 characters (got ${#salt})${NC}"; return 1
  fi
  if [[ ! "$salt" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo -e "${RED}Salt must contain only: a-z A-Z 0-9 _ -${NC}"; return 1
  fi

  local orig; orig=$(count_salt "$binary" "$ORIGINAL_SALT")
  if [[ "$orig" -eq 0 ]]; then
    if [[ $(count_salt "$binary" "$salt") -gt 0 ]]; then
      echo -e "  ${GREEN}✓${NC} Already patched with this salt."; return 0
    fi
    echo -e "  ${YELLOW}Binary already patched with a different salt.${NC}"
    echo "  Run ${BOLD}$0 --restore${NC} first, then try again."; return 1
  fi

  [[ ! -f "$backup" ]] && { cp "$binary" "$backup"; echo -e "  ${DIM}Backup created${NC}"; }
  sed -i "s/$ORIGINAL_SALT/$salt/g" "$binary"

  # macOS codesign
  if [[ "$(uname)" == "Darwin" ]] && command -v codesign &>/dev/null; then
    codesign --force --sign - "$binary" 2>/dev/null && echo -e "  ${DIM}Re-signed (macOS)${NC}" || true
  fi

  [[ $(count_salt "$binary" "$ORIGINAL_SALT") -ne 0 ]] && { echo -e "${RED}Patch failed${NC}"; return 1; }

  # Keep companion soul (name/personality) — bones regenerate from new salt.
  # Only clear if user hasn't hatched yet (no companion in config).
  return 0
}

do_restore() {
  local binary; binary="$(resolve_binary)"; local backup="${binary}.original"
  [[ ! -f "$backup" ]] && { echo -e "${RED}No backup found${NC}"; exit 1; }
  cp "$backup" "$binary"; chmod +x "$binary"
  [[ "$(uname)" == "Darwin" ]] && command -v codesign &>/dev/null && codesign --force --sign - "$binary" 2>/dev/null || true
  echo -e "${GREEN}✓${NC} Restored original binary. Restart Claude Code."
}

# ═══════════════════════════════════════════════════════════════════════════════
# Help
# ═══════════════════════════════════════════════════════════════════════════════

print_help() {
  cat <<'EOF'

better-buddy — Choose your own Claude Code companion

USAGE
  ./better-buddy                           Interactive mode
  ./better-buddy [trait flags]             Forge + patch in one go
  ./better-buddy --current                 Show current companion
  ./better-buddy --check                   Show patch status
  ./better-buddy --restore                 Undo patch
  ./better-buddy --salt "SALT"             Skip forge, just patch

TRAITS (all optional — omit to accept any value)
  --species <name>     duck goose blob cat dragon octopus owl penguin
                       turtle snail ghost axolotl capybara cactus robot
                       rabbit mushroom chonk
  --rarity <name>      common uncommon rare epic legendary
  --eye <char>         · ✦ × ◉ @ °
  --hat <name>         none crown tophat propeller halo wizard beanie tinyduck
  --shiny / --no-shiny
  --min-<stat> <n>     debugging patience chaos wisdom snark (0-100)

OPTIONS
  --uuid <id>          Override auto-detected UUID
  --count <n>          Salts to find (default: 5)
  --max <n>            Max attempts in millions (default: 500)
  --apply              Auto-apply first match

EXAMPLES
  ./better-buddy --species dragon --rarity legendary --shiny
  ./better-buddy --species cat --count 3
  ./better-buddy --rarity epic --min-chaos 80
  ./better-buddy --restore

EOF
}

# ═══════════════════════════════════════════════════════════════════════════════
# Main
# ═══════════════════════════════════════════════════════════════════════════════

MODE="forge"
FORGE_ARGS=()
MANUAL_UUID=""
MANUAL_SALT=""
AUTO_APPLY=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --current|current)   MODE="current"; shift ;;
    --check|check)       MODE="check"; shift ;;
    --restore|restore)   MODE="restore"; shift ;;
    --help|-h|help)      MODE="help"; shift ;;
    --apply)    AUTO_APPLY=true; shift ;;
    --uuid)     MANUAL_UUID="${2:?--uuid requires a value}"; shift 2 ;;
    --salt)     MANUAL_SALT="${2:?--salt requires a value}"; MODE="patch-only"; shift 2 ;;
    *)          FORGE_ARGS+=("$1"); shift ;;
  esac
done

# ── Simple modes ──────────────────────────────────────────────────────────────

case "$MODE" in
  help)    print_help; exit 0 ;;
  restore) check_claude; do_restore; exit 0 ;;
  check)
    check_claude; check_python
    local_binary="$(resolve_binary)"
    COMP_LINE=$(python3 -c "
import json
for p in '$(config_paths)'.split():
    try:
        c = json.load(open(p)).get('companion')
        if c: print(c.get('name','?')); break
    except: pass
else: print('none')
" 2>/dev/null)
    PATCH=""
    is_patched "$local_binary" && PATCH="${GREEN}patched${NC}" || PATCH="${YELLOW}not patched${NC}"
    echo -e "${BOLD}better-buddy${NC}  ${COMP_LINE:-none} (${PATCH})"
    exit 0
    ;;
  current)
    check_claude; check_python; check_bun
    UUID="${MANUAL_UUID:-}"
    if [[ -z "$UUID" ]]; then
      det=$(detect_uuid) || { echo -e "${RED}UUID not found. Pass --uuid${NC}"; exit 1; }
      UUID=$(echo "$det" | cut -d'|' -f2)
    fi
    show_companion
    echo ""
    FORCE_COLOR=1 bun run "$SCRIPT_DIR/forge.ts" --uuid "$UUID" --current 2>&1 \
      | grep -v "Auto-detected" | grep -v "^Your current" | grep -v "^$"
    exit 0
    ;;
  patch-only)
    check_claude; check_python
    BINARY="$(resolve_binary)"
    if do_patch "$BINARY" "$MANUAL_SALT"; then
      save_salt "$MANUAL_SALT"
      echo -e "${GREEN}✓${NC} Patched. Restart Claude Code — your companion name stays, new bones apply."
      echo -e "${DIM}Salt saved to $CONFIG_FILE${NC}"
    fi
    exit 0
    ;;
esac

# ═══════════════════════════════════════════════════════════════════════════════
# Forge mode
# ═══════════════════════════════════════════════════════════════════════════════

# ── Setup (silent unless something needs installing) ──────────────────────────

check_claude; check_python; check_bun
BINARY="$(resolve_binary)"

if [[ -n "$MANUAL_UUID" ]]; then
  UUID="$MANUAL_UUID"; AUTH_TYPE="manual"
else
  DETECT=$(detect_uuid 2>/dev/null) || DETECT=""
  if [[ -z "$DETECT" ]]; then
    echo -e "${YELLOW}Could not auto-detect UUID.${NC}"
    echo -e "${DIM}Check ~/.claude.json → oauthAccount.accountUuid or userID${NC}"
    read -r -p "UUID: " UUID
    [[ -z "$UUID" ]] && { echo -e "${RED}No UUID.${NC}"; exit 1; }
    AUTH_TYPE="manual"
  else
    AUTH_TYPE=$(echo "$DETECT" | cut -d'|' -f1)
    UUID=$(echo "$DETECT" | cut -d'|' -f2)
  fi
fi

# ── Show current state (one line) ────────────────────────────────────────────

COMP_NAME=$(python3 -c "
import json
for p in $(python3 -c "import json; print(json.dumps('$(config_paths)'.split()))"):
    try:
        c = json.load(open(p)).get('companion')
        if c: print(c.get('name','?')); break
    except: pass
" 2>/dev/null || echo "none")

echo ""
PATCH_STATUS=""
is_patched "$BINARY" && PATCH_STATUS="${GREEN}patched${NC}" || PATCH_STATUS="${YELLOW}original${NC}"
echo -e "${BOLD}${MAGENTA}better-buddy${NC}  ${DIM}│${NC}  ${COMP_NAME:-none} ${DIM}(${NC}${PATCH_STATUS}${DIM})${NC}  ${DIM}│${NC}  ${DIM}${UUID:0:4}**** ${AUTH_TYPE}${NC}"
echo ""

# ── Collect traits ────────────────────────────────────────────────────────────

if [[ ${#FORGE_ARGS[@]} -eq 0 ]]; then
  echo -e "${BOLD}Usage:${NC} ./better-buddy ${CYAN}--species${NC} dragon ${CYAN}--rarity${NC} legendary ${CYAN}--shiny${NC}"
  echo ""
  echo -e "  ${CYAN}--species${NC}   duck goose blob cat dragon octopus owl penguin turtle"
  echo -e "             snail ghost axolotl capybara cactus robot rabbit mushroom chonk"
  echo -e "  ${CYAN}--rarity${NC}    common  uncommon  rare  epic  legendary"
  echo -e "  ${CYAN}--eye${NC}       ·  ✦  ×  ◉  @  °"
  echo -e "  ${CYAN}--hat${NC}       crown  tophat  propeller  halo  wizard  beanie  tinyduck"
  echo -e "  ${CYAN}--shiny${NC}     ${DIM}(1% chance — takes longer)${NC}"
  echo -e "  ${CYAN}--min-chaos${NC} ${DIM}0-100 (also: --min-debugging, --min-patience, --min-wisdom, --min-snark)${NC}"
  echo ""
  echo -e "${DIM}Omit any flag to accept any value. --count N for more results.${NC}"
  exit 0
fi

# ── Forge ─────────────────────────────────────────────────────────────────────

FORGE_OUTPUT=$(FORCE_COLOR=1 bun run "$SCRIPT_DIR/forge.ts" --uuid "$UUID" "${FORGE_ARGS[@]}" 2>&1)

# Show only the matches and summary — strip header, current companion, banner
echo "$FORGE_OUTPUT" \
  | sed '/^Current companion/,/^$/d' \
  | grep -v "better-buddy forge" \
  | sed '/^Auto-detected/d' \
  | sed '/^Searching for:/,/^$/d' \
  | sed '/^Estimated odds/d' \
  | sed '/^Finding/d' \
  | grep -v "^Apply with:" \
  | grep -v "patch\.sh" \
  | sed '/^$/N;/^\n$/d'

# Extract salts (strip ANSI)
CLEAN=$(echo "$FORGE_OUTPUT" | sed 's/\x1b\[[0-9;]*m//g')
mapfile -t SALTS < <(echo "$CLEAN" | grep -oP '(?<=salt )\S+' || true)

[[ ${#SALTS[@]} -eq 0 ]] && { echo -e "${YELLOW}No matches. Relax constraints.${NC}"; exit 1; }

# ── Pick and patch ────────────────────────────────────────────────────────────

if $AUTO_APPLY; then
  CHOSEN="${SALTS[0]}"
elif [[ ${#SALTS[@]} -eq 1 ]]; then
  echo ""
  read -r -p "$(echo -e "Apply ${CYAN}${SALTS[0]}${NC}? [Y/n] ")" resp
  [[ "${resp:-Y}" =~ ^[Nn]$ ]] && { echo -e "${DIM}Later: ./better-buddy --salt \"${SALTS[0]}\"${NC}"; exit 0; }
  CHOSEN="${SALTS[0]}"
else
  echo ""
  for i in "${!SALTS[@]}"; do echo -e "  ${BOLD}$((i+1))${NC}. ${SALTS[$i]}"; done
  echo -e "  ${DIM}0. skip${NC}"
  read -r -p "$(echo -e "${BOLD}#${NC} [1]: ")" choice; choice="${choice:-1}"
  [[ "$choice" == "0" ]] && { echo -e "${DIM}Later: ./better-buddy --salt \"SALT\"${NC}"; exit 0; }
  idx=$((choice-1))
  [[ $idx -lt 0 || $idx -ge ${#SALTS[@]} ]] && { echo -e "${RED}Invalid.${NC}"; exit 1; }
  CHOSEN="${SALTS[$idx]}"
fi

if do_patch "$BINARY" "$CHOSEN"; then
  save_salt "$CHOSEN"
  echo ""
  echo -e "${GREEN}✓${NC} Patched. Restart Claude Code — your companion name stays, new bones apply."
  echo -e "${DIM}Salt saved to $CONFIG_FILE — buddy-ensure will re-apply after updates.${NC}"
fi
